    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst production = data.production_types;\n\nconst renewableShare = production.find(p => p.name === 'Renewable share of load');\nconst windOnshore = production.find(p => p.name === 'Wind onshore');\nconst windOffshore = production.find(p => p.name === 'Wind offshore');\nconst solar = production.find(p => p.name === 'Solar');\nconst load = production.find(p => p.name === 'Load');\n\nconst lastIndex = renewableShare.data.length - 1;\n\nconst renewableFeedIn = renewableShare.data[lastIndex];\nconst h1Triggered = renewableFeedIn < 20;\n\nreturn [{\n  json: {\n    renewableFeedIn: renewableFeedIn.toFixed(2),\n    h1Triggered,\n    windOnshore: windOnshore.data[lastIndex],\n    windOffshore: windOffshore.data[lastIndex],\n    solar: solar.data[lastIndex],\n    load: load.data[lastIndex],\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "8dfc2266-04fb-4d02-8fd5-278dee904264",
